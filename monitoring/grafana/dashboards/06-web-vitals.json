{
  "uid": "itsm-web-vitals",
  "title": "ITSM Web Vitals",
  "description": "Core Web Vitals 모니터링 — LCP, FID, CLS, TTFB, FCP, INP 성능 지표",
  "tags": [
    "itsm",
    "performance",
    "web-vitals"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "label": "데이터소스"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Core Web Vitals 현재 상태",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "LCP (Largest Contentful Paint)",
      "description": "최대 콘텐츠 요소 렌더링 시간. 좋음: <2500ms, 개선 필요: 2500~4000ms, 나쁨: >4000ms",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 6000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2500
              },
              {
                "color": "red",
                "value": 4000
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"LCP\"}",
          "legendFormat": "LCP",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "FID (First Input Delay)",
      "description": "첫 번째 입력 지연 시간. 좋음: <100ms, 개선 필요: 100~300ms, 나쁨: >300ms",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 500,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"FID\"}",
          "legendFormat": "FID",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CLS (Cumulative Layout Shift)",
      "description": "누적 레이아웃 이동 점수. 좋음: <0.1, 개선 필요: 0.1~0.25, 나쁨: >0.25",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 0.5,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.25
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"CLS\"}",
          "legendFormat": "CLS",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "TTFB (Time to First Byte)",
      "description": "첫 번째 바이트 수신 시간. 좋음: <800ms, 개선 필요: 800~1800ms, 나쁨: >1800ms",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 3000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 800
              },
              {
                "color": "red",
                "value": 1800
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"TTFB\"}",
          "legendFormat": "TTFB",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "FCP (First Contentful Paint)",
      "description": "첫 번째 콘텐츠 렌더링 시간. 좋음: <1800ms, 개선 필요: 1800~3000ms, 나쁨: >3000ms",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 5000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1800
              },
              {
                "color": "red",
                "value": 3000
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"FCP\"}",
          "legendFormat": "FCP",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "INP (Interaction to Next Paint)",
      "description": "다음 페인트까지의 상호작용 시간. 좋음: <200ms, 개선 필요: 200~500ms, 나쁨: >500ms",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "max": 800,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 200
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"INP\"}",
          "legendFormat": "INP",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "등급 분포 및 추이",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "fieldConfig": {
        "defaults": {}
      }
    },
    {
      "id": 9,
      "type": "barchart",
      "title": "Web Vitals 등급 분포",
      "description": "지표별 good / needs-improvement / poor 판정 건수",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": 0,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "barWidth": 0.7,
        "groupWidth": 0.7
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          },
          "noValue": "0"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "good"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "needs-improvement"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2CC0C",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "poor"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "count by (metric_name, rating) (web_vitals_value)",
          "legendFormat": "{{rating}} — {{metric_name}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "시간별 LCP 추이",
      "description": "최근 1시간 LCP 값 변화 추이",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2500
              },
              {
                "color": "red",
                "value": 4000
              }
            ]
          },
          "noValue": "0"
        }
      },
      "targets": [
        {
          "expr": "web_vitals_value{metric_name=\"LCP\"}",
          "legendFormat": "LCP ({{rating}})",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    }
  ]
}
