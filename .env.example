# ───────────────────────────────────────────
# Docker 이미지 (CI/CD 배포 시 설정, 로컬 개발 시 불필요)
# ───────────────────────────────────────────
# 레지스트리 이미지 경로 (예: registry.gitlab.com/myorg/itsm/itsm-api)
IMAGE_API=
IMAGE_WEB=
# 배포할 이미지 태그 (CI가 자동 주입, 예: dev-20250313, v1.2.3)
IMAGE_API_TAG=latest
IMAGE_WEB_TAG=latest

# ───────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────
POSTGRES_DB=itsm
POSTGRES_USER=itsm
POSTGRES_PASSWORD=<REQUIRED: 강력한 랜덤 비밀번호 설정, 예: openssl rand -hex 16>

# ───────────────────────────────────────────
# 백업 (M3: /tmp 대신 영구 볼륨 경로 설정 권장)
# ───────────────────────────────────────────
# docker-compose에서 볼륨 마운트 후 해당 경로 지정
# BACKUP_DIR=/var/backups/itsm

# ───────────────────────────────────────────
# MinIO (H-02: 기본값 없음 — 반드시 강력한 자격증명 설정 필요)
# ───────────────────────────────────────────
MINIO_ACCESS_KEY=<REQUIRED: 최소 8자 사용자명, 예: openssl rand -hex 8>
MINIO_SECRET_KEY=<REQUIRED: 최소 16자 비밀번호, 예: openssl rand -hex 16>
# MINIO_SECURE=false  # 로컬 개발 환경에서만 사용 (기본값 true)

# ───────────────────────────────────────────
# GitLab
# ───────────────────────────────────────────
GITLAB_ROOT_PASSWORD=<REQUIRED: 강력한 랜덤 비밀번호 설정>

# GitLab OAuth 앱에서 발급 (GitLab → Admin → Applications)
GITLAB_OAUTH_CLIENT_ID=your_client_id
GITLAB_OAUTH_CLIENT_SECRET=your_client_secret
# 프론트엔드 콜백 페이지 사용 (추천): GitLab OAuth App에도 동일하게 등록해야 함
GITLAB_OAUTH_REDIRECT_URI=http://localhost:8111/auth/callback

# GitLab 프로젝트 액세스 토큰 (scopes: api, admin 권한 불필요)
# GitLab → Project → Settings → Access Tokens 에서 생성 (access level: Maintainer)
GITLAB_PROJECT_TOKEN=your_project_token

# 공용 라벨을 관리할 GitLab 그룹 (선택 — 설정 시 그룹 라벨로 등록, 미설정 시 프로젝트 라벨)
# GitLab → Group → Settings → Access Tokens 에서 그룹 토큰 생성 (access level: Maintainer)
GITLAB_GROUP_ID=
GITLAB_GROUP_TOKEN=

# ITSM 전용 GitLab 프로젝트 ID
GITLAB_PROJECT_ID=1

# GitLab 웹훅 검증 시크릿 (프로덕션 필수 — 미설정 시 기동 불가)
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
GITLAB_WEBHOOK_SECRET=<REQUIRED: 랜덤 시크릿>
# GitLab이 ITSM으로 이벤트를 보낼 URL (개발 프로젝트 전달 실시간 동기화용)
# Docker 내부: http://itsm-api:8000/webhooks/gitlab
ITSM_WEBHOOK_URL=http://itsm-api:8000/webhooks/gitlab

# ───────────────────────────────────────────
# Redis
# ───────────────────────────────────────────
# M-4: Redis 인증 비밀번호 (예: openssl rand -hex 16)
REDIS_PASSWORD=<REQUIRED: 예: openssl rand -hex 16>

# ───────────────────────────────────────────
# ITSM API
# ───────────────────────────────────────────
# 최소 32자 랜덤 문자열 (예: openssl rand -hex 32)
SECRET_KEY=<REQUIRED: 최소 32자 랜덤 문자열, 예: openssl rand -hex 32>

# GitLab refresh token 암호화 키 (Fernet) — 프로덕션 필수 (미설정 시 기동 불가)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# 백업 암호화 전용 키 (SECRET_KEY와 독립 관리 권장)
# 미설정 시 SECRET_KEY에서 파생 (하위 호환 — 신규 설치는 설정 권장)
# 생성: python -c "import secrets; print(secrets.token_hex(32))"
BACKUP_ENCRYPTION_KEY=

ENVIRONMENT=production
# 리프레시 토큰 만료 기간 (일) — 보안상 7일 권장 (기본값)
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_ACTIVE_SESSIONS=5

# GitLab 외부 접근 URL (브라우저에서 직접 접근하는 주소, API URL과 다를 수 있음)
GITLAB_EXTERNAL_URL=http://localhost:8929
# 프론트엔드 URL (이메일 알림 링크 등에 사용)
FRONTEND_URL=http://localhost:8111

# ───────────────────────────────────────────
# ITSM Web (빌드 시 주입되는 환경변수)
# ───────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8111/api
NEXT_PUBLIC_GITLAB_URL=http://localhost:8929

# ───────────────────────────────────────────
# Nginx
# ───────────────────────────────────────────
APP_PORT=8111
# Prometheus metrics 엔드포인트 보호 토큰 (예: openssl rand -hex 24)
METRICS_TOKEN=<REQUIRED: 예: openssl rand -hex 24>

# ───────────────────────────────────────────
# 이메일 알림 (선택)
# ───────────────────────────────────────────
NOTIFICATION_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ITSM Portal <noreply@company.com>
SMTP_TLS=true
IT_TEAM_EMAIL=

# ───────────────────────────────────────────
# 텔레그램 알림 (선택)
# ───────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────
# 모니터링 (docker compose --profile monitoring up)
# ───────────────────────────────────────────
GRAFANA_PASSWORD=<REQUIRED: 강력한 비밀번호 설정>

# ───────────────────────────────────────────
# 모니터링 포트
# ───────────────────────────────────────────
GRAFANA_PORT=3001
# nginx 프록시 경로 사용 (직접 포트 접속 X)
GRAFANA_ROOT_URL=http://localhost:8111/grafana/

# ───────────────────────────────────────────
# ClamAV 바이러스 스캔
# ───────────────────────────────────────────
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# ───────────────────────────────────────────
# Celery Flower 인증 (필수 — 미설정 시 기동 불가)
# ───────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=<REQUIRED: 예: openssl rand -hex 12>

# ───────────────────────────────────────────
# API 워커 수 (gunicorn 멀티 프로세스, 기본 2)
# 권장: (2 * CPU 코어 수) + 1
# ───────────────────────────────────────────
WORKERS=2

# ───────────────────────────────────────────
# DB 연결 풀 (선택 — 기본값으로 대부분 충분)
# ───────────────────────────────────────────
# 권장: (WORKERS * 10) + celery worker concurrency(4) * 3
DB_POOL_SIZE=30
DB_MAX_OVERFLOW=20
