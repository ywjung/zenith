# ───────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────
POSTGRES_DB=itsm
POSTGRES_USER=itsm
POSTGRES_PASSWORD=changeme

# ───────────────────────────────────────────
# GitLab
# ───────────────────────────────────────────
GITLAB_ROOT_PASSWORD=changeme

# GitLab OAuth 앱에서 발급 (GitLab → Admin → Applications)
GITLAB_OAUTH_CLIENT_ID=your_client_id
GITLAB_OAUTH_CLIENT_SECRET=your_client_secret
GITLAB_OAUTH_REDIRECT_URI=http://localhost:8111/api/auth/callback

# GitLab 프로젝트 액세스 토큰 (scopes: api, admin 권한 불필요)
# GitLab → Project → Settings → Access Tokens 에서 생성 (access level: Maintainer)
GITLAB_PROJECT_TOKEN=your_project_token

# 공용 라벨을 관리할 GitLab 그룹 (선택 — 설정 시 그룹 라벨로 등록, 미설정 시 프로젝트 라벨)
# GitLab → Group → Settings → Access Tokens 에서 그룹 토큰 생성 (access level: Maintainer)
GITLAB_GROUP_ID=
GITLAB_GROUP_TOKEN=

# ITSM 전용 GitLab 프로젝트 ID
GITLAB_PROJECT_ID=1

# GitLab 웹훅 검증 시크릿 (선택)
GITLAB_WEBHOOK_SECRET=
# GitLab이 ITSM으로 이벤트를 보낼 URL (개발 프로젝트 전달 실시간 동기화용)
# Docker 내부: http://itsm-api:8000/webhooks/gitlab
ITSM_WEBHOOK_URL=http://itsm-api:8000/webhooks/gitlab

# ───────────────────────────────────────────
# Redis
# ───────────────────────────────────────────
# M-4: Redis 인증 비밀번호 (예: openssl rand -hex 16)
REDIS_PASSWORD=change_me_redis_password

# ───────────────────────────────────────────
# ITSM API
# ───────────────────────────────────────────
# 최소 32자 랜덤 문자열 (예: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_random_secret_key_32chars

# GitLab refresh token 암호화 키 (Fernet)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

ENVIRONMENT=production
REFRESH_TOKEN_EXPIRE_DAYS=30

# ───────────────────────────────────────────
# ITSM Web (빌드 시 주입되는 환경변수)
# ───────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8111/api
NEXT_PUBLIC_GITLAB_URL=http://localhost:8929

# ───────────────────────────────────────────
# Nginx
# ───────────────────────────────────────────
APP_PORT=8111

# ───────────────────────────────────────────
# 이메일 알림 (선택)
# ───────────────────────────────────────────
NOTIFICATION_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ITSM Portal <noreply@company.com>
SMTP_TLS=true
IT_TEAM_EMAIL=

# ───────────────────────────────────────────
# 텔레그램 알림 (선택)
# ───────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────
# 모니터링 (docker compose --profile monitoring up)
# ───────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ───────────────────────────────────────────
# 모니터링 포트
# ───────────────────────────────────────────
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://localhost:3001

# ───────────────────────────────────────────
# ClamAV 바이러스 스캔
# ───────────────────────────────────────────
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
